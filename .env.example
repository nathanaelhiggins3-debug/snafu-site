# Copy this file to ".env" and fill in your Stripe TEST secret key.
# .env is gitignored and must NEVER be committed. This .example file is safe.
#
# Get your test key at: https://dashboard.stripe.com/test/apikeys
# It starts with "sk_test_". Only the SECRET key is needed — the hosted
# checkout flow redirects to a Stripe URL, so no publishable key is required.

STRIPE_SECRET_KEY=sk_test_replace_me
